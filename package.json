{
  "name": "lw-calc",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "git@github.com:dudeist42/lightweight-calc-app.git",
  "author": "dudeist42",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build:lw-math": "pnpm --filter lw-math build",
    "build:calcjs-app": "pnpm --filter calcjs-app build",
    "test:lw-math": "pnpm --filter lw-math test",
    "test:calcjs-app": "pnpm --filter calcjs-app test",
    "test": "pnpm test:lw-math && pnpm test:calcjs-app",
    "build": "pnpm build:lw-math && pnpm build:calcjs-app",
    "dev:lw-math": "pnpm build:lw-math",
    "dev:calcjs-app": "pnpm --filter calcjs-app dev",
    "dev": "pnpm run /^dev:.*/",
    "preview": "pnpm build && pnpm --filter calcjs-app preview",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "prettier": "prettier . -c",
    "prettier:fix": "prettier . --write"
  },
  "devDependencies": {
    "eslint": "10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "packageManager": "pnpm@10.7.0",
  "pnpm": {
    "overrides": {
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "happy-dom@<20.8.9": ">=20.8.9",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "vite@>=8.0.0 <=8.0.4": ">=8.0.5"
    }
  }
}
